# Frontend env vars (local-dev).
#
# NEXT_PUBLIC_* — доступны клиенту (передаются в browser bundle).
# Остальные — server-only (доступны route handlers и server components).

# Keycloak OIDC discovery
NEXT_PUBLIC_KC_URL=http://localhost:8080
NEXT_PUBLIC_KC_REALM=rehome
NEXT_PUBLIC_KC_CLIENT_ID=rehome-web-spa

# OAuth redirect URI — должен совпадать с realm config (см. ADR-0007)
KC_REDIRECT_URI=http://localhost:3000/api/auth/callback/keycloak
KC_POST_LOGOUT_URI=http://localhost:3000/

# reHome KB — infra environment variables (local-dev)
#
# Скопируйте этот файл как `.env` в той же папке (`infra/.env`) и
# при необходимости измените значения. Файл `.env` в `.gitignore`,
# реальные секреты в нём не попадают в репозиторий.
#
# Production значения — через Kubernetes Secret / vault, не через .env
# (см. ADR-0007 «Local-dev credentials»).

# Keycloak admin (Admin Console http://localhost:8080)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Keycloak Postgres backend
POSTGRES_KEYCLOAK_DB=keycloak
POSTGRES_KEYCLOAK_USER=keycloak
POSTGRES_KEYCLOAK_PASSWORD=keycloak

# Keycloak m2m client (rehome-platform-m2m)
# Этот же secret сохранён в infra/keycloak/realm-export.json для импорта
# realm; смены требуют пере-импорта realm или ручного обновления через
# Admin Console.
KEYCLOAK_M2M_CLIENT_SECRET=rehome-platform-m2m-local-dev-secret

# Postgres для kb-API (articles/documents/...). Отдельный инстанс от
# Keycloak-Postgres. Backend читает через DATABASE_URL (см.
# backend/src/api/config.py).
POSTGRES_KB_DB=rehome_kb
POSTGRES_KB_USER=kb
POSTGRES_KB_PASSWORD=kb
